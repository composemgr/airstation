# Airstation - Self-hosted internet radio station manager
# Copy to app.env and fill in your values

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# Application secrets (must be at least 32 characters)
APP_JWT_TOKEN=changeme_jwt_sign_token_min_32_chars
APP_SECRET_KEY=changeme_secret_key_min_32_chars
